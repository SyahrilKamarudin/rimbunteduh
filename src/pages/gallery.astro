---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GalleryGrid from '../components/GalleryGrid';
---
<Layout title="Gallery | Rimbun Teduh Homestead Farm" description="A glimpse of our homestead — farm, stay, activities, and food.">
  <Nav active="gallery" />

  <section class="mx-auto mt-4 max-w-content-lg px-6 text-center md:px-16">
    <div data-i18n="gallery.gallery.eyebrow" class="mb-3 text-xs font-semibold tracking-[2px] text-gold">GALLERY</div>
    <div data-i18n="gallery.gallery.heading" class="mb-8 font-serif text-3xl text-ink md:text-[42px]">A Glimpse of Our Homestead</div>
  </section>

  <section class="mx-auto mb-24 max-w-content-lg px-6 md:px-16">
    <GalleryGrid client:load />
  </section>

  <Footer />
</Layout>
