---
import LogoMark from './LogoMark.astro';

interface Props {
  active?: 'home' | 'about' | 'experiences' | 'gallery' | 'location' | '';
}
const { active = '' } = Astro.props;

const links = [
  { key: 'home', href: '/', i18n: 'nav.home', label: 'Home' },
  { key: 'about', href: '/about', i18n: 'nav.about', label: 'About' },
  { key: 'experiences', href: '/experiences', i18n: 'nav.experiences', label: 'Experiences' },
  { key: 'gallery', href: '/gallery', i18n: 'nav.gallery', label: 'Gallery' },
  { key: 'location', href: '/location', i18n: 'nav.location', label: 'Location' },
];
---
<nav class="sticky top-0 z-50 border-b border-forest/[0.12] bg-cream">
  <div class="flex items-center justify-between gap-5 px-6 py-4 md:px-12">
    <a href="/" class="flex flex-shrink-0 items-center gap-3 no-underline">
      <LogoMark class="h-11 w-11" />
      <div class="flex flex-col leading-tight whitespace-nowrap">
        <span class="font-serif text-[17px] font-semibold tracking-[0.3px] text-forest">RIMBUN TEDUH</span>
        <span class="text-[9px] tracking-[1.5px] text-muted-2">HOMESTEAD FARM</span>
      </div>
    </a>

    <div class="hidden flex-shrink-0 items-center gap-6 lg:flex">
      {links.map((link) => (
        <a
          href={link.href}
          data-i18n={link.i18n}
          class={
            active === link.key
              ? 'border-b-2 border-gold pb-1 text-[15px] font-semibold text-forest no-underline'
              : 'text-[15px] text-[#3d4a37] no-underline'
          }
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden flex-shrink-0 items-center gap-3.5 lg:flex">
      <div class="flex overflow-hidden rounded-full border-[1.5px] border-forest/20">
        <button data-lang-btn="en" class="px-3.5 py-1.5 text-xs font-bold text-white bg-forest" type="button">EN</button>
        <button data-lang-btn="ms" class="px-3.5 py-1.5 text-xs font-semibold text-[#3d4a37]" type="button">BM</button>
      </div>
      <a
        href="/booking"
        data-i18n="nav.bookNow"
        class="flex items-center gap-2 rounded-lg bg-gold px-5 py-3 text-sm font-semibold text-white no-underline hover:bg-gold-dark hover:text-white"
      >Book Now</a>
    </div>

    <button
      id="nav-toggle"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg border-[1.5px] border-forest/20 lg:hidden"
    >
      <svg id="nav-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1E3A2B" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      <svg id="nav-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1E3A2B" stroke-width="2" class="hidden"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden flex-col gap-1 border-t border-forest/[0.12] bg-cream px-6 pb-6 pt-2 lg:hidden">
    {links.map((link) => (
      <a
        href={link.href}
        data-i18n={link.i18n}
        class={
          active === link.key
            ? 'rounded-lg bg-forest/[0.06] px-3 py-3 text-[15px] font-semibold text-forest no-underline'
            : 'rounded-lg px-3 py-3 text-[15px] text-[#3d4a37] no-underline'
        }
      >
        {link.label}
      </a>
    ))}
    <div class="mt-3 flex items-center gap-3.5 px-3">
      <div class="flex overflow-hidden rounded-full border-[1.5px] border-forest/20">
        <button data-lang-btn="en" class="px-3.5 py-1.5 text-xs font-bold text-white bg-forest" type="button">EN</button>
        <button data-lang-btn="ms" class="px-3.5 py-1.5 text-xs font-semibold text-[#3d4a37]" type="button">BM</button>
      </div>
      <a
        href="/booking"
        data-i18n="nav.bookNow"
        class="flex flex-1 items-center justify-center gap-2 rounded-lg bg-gold px-5 py-3 text-sm font-semibold text-white no-underline hover:bg-gold-dark hover:text-white"
      >Book Now</a>
    </div>
  </div>
</nav>

<script>
  function initNavToggle() {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    if (!toggle || !menu || !iconOpen || !iconClose) return;

    function closeMenu() {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      menu.classList.toggle('hidden', !isHidden);
      menu.classList.toggle('flex', isHidden);
      iconOpen.classList.toggle('hidden', isHidden);
      iconClose.classList.toggle('hidden', !isHidden);
      toggle.setAttribute('aria-expanded', String(isHidden));
    });

    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  }

  document.addEventListener('DOMContentLoaded', initNavToggle);
</script>
